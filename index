<!DOCTYPE html>
<html lang="es-MX">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <title>TAXÍMETRO EDOMEX</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; min-height: 100dvh; display: flex; justify-content: center; align-items: center; padding: 10px; overflow: hidden; }
        .taximetro-container { background: white; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.3); max-width: 500px; width: 100%; height: 95vh; height: 95dvh; display: flex; flex-direction: column; overflow: hidden; }
        .header { background: linear-gradient(135deg, #006400 0%, #228B22 100%); color: #FFD700; padding: 10px 15px; border-radius: 12px 12px 0 0; display: flex; align-items: center; justify-content: center; gap: 8px; position: relative; overflow: hidden; flex-shrink: 0; }
        .header::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%); animation: shine 3s infinite; }
        @keyframes shine { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
        .taxi-icon { font-size: 1.5em; animation: bounce 2s infinite; filter: drop-shadow(0 3px 3px rgba(0,0,0,0.3)); position: relative; z-index: 1; }
        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
        .header-text { position: relative; z-index: 1; text-align: left; }
        .header h1 { font-size: 1.1em; text-shadow: 0 0 8px rgba(255,215,0,0.5); letter-spacing: 1px; margin: 0; line-height: 1.2; }
        .edomex-badge { background: rgba(255,215,0,0.2); color: #FFD700; padding: 2px 6px; border-radius: 8px; font-size: 0.6em; display: inline-block; border: 1px solid #FFD700; }
        .tarifa-indicator { padding: 2px 6px; border-radius: 10px; font-weight: bold; font-size: 0.65em; position: absolute; top: 6px; right: 6px; z-index: 1; }
        .tarifa-diurna { background: #ffd32a; color: #2d3436; }
        .tarifa-nocturna { background: #2c3e50; color: #f1c40f; }
        
        /* CONTENIDO PRINCIPAL - No scroll */
        .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; padding: 10px; }
        
        .hora-actual { text-align: center; color: #666; font-size: 0.7em; flex-shrink: 0; }
        .debug-info { background: #fff3cd; border: 1px solid #ffc107; padding: 5px; border-radius: 5px; font-size: 0.6em; color: #856404; display: none; flex-shrink: 0; }
        .debug-info.show { display: block; }
        
        /* DISPLAY PRINCIPAL - Importe GRANDE */
        .display-principal { background: #000; color: #00ff88; padding: 15px; border-radius: 12px; font-family: 'Courier New', monospace; flex-shrink: 0; }
        .tarifa-actual { font-size: 4.5em; text-align: center; font-weight: bold; text-shadow: 0 0 20px rgba(0,255,136,0.9); margin: 5px 0; transition: all 0.3s; line-height: 1; }
        .tarifa-actual.salto { color: #FFD700; text-shadow: 0 0 35px rgba(255,215,0,0.9); transform: scale(1.05); }
        .info-viaje { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; margin: 8px 0; }
        .info-item { background: rgba(0,255,136,0.1); padding: 5px; border-radius: 6px; text-align: center; }
        .info-label { font-size: 0.55em; color: #00cc6a; margin-bottom: 2px; }
        .info-value { font-size: 0.8em; color: #00ff88; transition: all 0.3s; }
        .info-value.saltando { color: #FFD700 !important; transform: scale(1.1); }
        .gps-status { display: flex; align-items: center; justify-content: center; margin: 5px 0; font-size: 0.65em; }
        .gps-dot { width: 6px; height: 6px; border-radius: 50%; margin-right: 4px; }
        .gps-active { background: #00ff88; box-shadow: 0 0 6px #00ff88; }
        .gps-inactive { background: #d63031; }
        .barra-estado { display: flex; justify-content: space-between; align-items: center; margin-top: 5px; padding: 4px 6px; background: rgba(0,255,136,0.05); border-radius: 4px; font-size: 0.55em; color: #00cc6a; }
        .estado-servicio-mini { padding: 2px 6px; border-radius: 8px; font-weight: bold; font-size: 0.8em; }
        .estado-libre-mini { background: #00b894; color: white; }
        .estado-ocupado-mini { background: #d63031; color: white; animation: pulse 1s infinite; }
        .estado-cobro-mini { background: #f39c12; color: white; animation: blinkYellow 0.8s infinite; }
        @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.8; } 100% { opacity: 1; } }
        @keyframes blinkYellow { 0%, 100% { background: #f39c12; box-shadow: 0 0 10px #f39c12; } 50% { background: #FFD700; box-shadow: 0 0 20px #FFD700; } }
        
        .espera-container { margin-top: 5px; flex-shrink: 0; }
        .espera-info-text { font-size: 0.6em; color: #FF9800; text-align: center; margin-bottom: 2px; font-weight: bold; display: none; }
        .espera-info-text.activo { display: block; animation: blink 1s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .progreso-espera { width: 100%; height: 6px; background: rgba(255,152,0,0.2); border-radius: 3px; overflow: hidden; }
        .progreso-espera-fill { height: 100%; background: linear-gradient(90deg, #FF9800, #FF5722); transition: width 1s linear; width: 0%; border-radius: 3px; }
        .coords-info { font-size: 0.5em; color: #555; text-align: center; }

        /* BOTONES */
        .btn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 8px 0; flex-shrink: 0; }
        .btn { padding: 12px; border: none; border-radius: 10px; font-weight: bold; cursor: pointer; transition: all 0.3s; text-transform: uppercase; letter-spacing: 1px; }
        .btn-iniciar { background: linear-gradient(135deg, #00b894, #00cec9); color: white; font-size: 1em; }
        .btn-detener { background: linear-gradient(135deg, #d63031, #e17055); color: white; font-size: 1em; }
        .btn-cobrar { background: linear-gradient(135deg, #f39c12, #e67e22); color: white; font-size: 0.9em; animation: blinkCobrar 0.8s infinite; display: none; }
        .btn-cobrar.activo { display: block; }
        .btn-cancelar-cobro { background: #95a5a6; color: white; font-size: 0.9em; display: none; }
        .btn-cancelar-cobro.activo { display: block; }
        @keyframes blinkCobrar { 0%, 100% { background: linear-gradient(135deg, #f39c12, #e67e22); box-shadow: 0 0 15px rgba(243,156,18,0.6); } 50% { background: linear-gradient(135deg, #FFD700, #f39c12); box-shadow: 0 0 30px rgba(255,215,0,0.9); } }
        .btn-maps { background: linear-gradient(135deg, #4285f4, #34a853); color: white; font-size: 0.75em; padding: 8px; display: flex; align-items: center; justify-content: center; gap: 5px; }
        .btn-config { background: #636e72; color: white; font-size: 0.7em; padding: 6px; }
        .btn-historial { background: linear-gradient(135deg, #6c5ce7, #a29bfe); color: white; font-size: 0.75em; }
        .btn-exportar { background: linear-gradient(135deg, #00b894, #00cec9); color: white; font-size: 0.75em; }
        .btn:active { transform: scale(0.95); }
        .btn:disabled { opacity: 0.5; cursor: not-allowed; }

        /* PÁGINA DE CONFIGURACIÓN */
        .config-page { display: none; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: white; z-index: 100; border-radius: 20px; overflow-y: auto; padding: 15px; }
        .config-page.activo { display: block; }
        .config-section { background: #f8f9fa; padding: 10px; border-radius: 10px; margin: 10px 0; }
        .config-bloqueada { filter: blur(4px); pointer-events: none; user-select: none; }
        .config-title { font-weight: bold; margin-bottom: 6px; color: #2d3436; font-size: 0.9em; display: flex; align-items: center; justify-content: space-between; }
        .input-group { display: flex; align-items: center; margin-bottom: 6px; flex-wrap: wrap; }
        .input-group label { flex: 1; font-size: 0.75em; margin-right: 6px; }
        .input-group input, .input-group select { width: 80px; padding: 5px; border: 2px solid #dee2e6; border-radius: 5px; font-size: 0.75em; text-align: center; }
        .input-group input[type="checkbox"] { width: auto; margin-left: 6px; }
        .tarifa-section { border-left: 3px solid #667eea; padding-left: 10px; margin: 8px 0; }
        .tarifa-nocturna-section { border-left-color: #2c3e50; }
        .btn-volver { background: #2d3436; color: white; font-size: 0.8em; padding: 10px; width: 100%; margin-top: 10px; }
        .btn-desbloquear { background: #27ae60; color: white; font-size: 0.65em; padding: 4px 8px; }

        /* HISTORIAL */
        .historial-page { display: none; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: white; z-index: 100; border-radius: 20px; overflow-y: auto; padding: 15px; }
        .historial-page.activo { display: block; }
        .historial-item { background: white; border-left: 4px solid #667eea; margin: 6px 0; padding: 8px; border-radius: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); font-size: 0.8em; }
        .historial-item.nocturno { border-left-color: #2c3e50; }
        .historial-item.cancelado { border-left-color: #e74c3c; background: #fff5f5; }
        .estadisticas-rapidas { display: grid; grid-template-columns: repeat(3, 1fr); gap: 5px; margin-bottom: 8px; font-size: 0.7em; }
        .stat-item { background: rgba(0,255,136,0.05); padding: 5px; border-radius: 5px; text-align: center; color: #00cc6a; }

        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); justify-content: center; align-items: center; z-index: 200; }
        .modal-content { background: white; padding: 20px; border-radius: 15px; max-width: 350px; width: 90%; text-align: center; }
        .modal-content h3 { margin-bottom: 10px; font-size: 1em; }
        .modal-content input { width: 100%; padding: 10px; margin: 8px 0; border: 2px solid #dee2e6; border-radius: 8px; font-size: 1em; text-align: center; }
        .modal-content textarea { width: 100%; height: 120px; margin: 8px 0; padding: 8px; border: 2px solid #dee2e6; border-radius: 8px; font-family: monospace; font-size: 0.75em; }
        .notification { position: fixed; top: 15px; right: 15px; background: #2d3436; color: white; padding: 10px 15px; border-radius: 8px; box-shadow: 0 5px 15px rgba(0,0,0,0.3); z-index: 300; animation: slideIn 0.3s ease; max-width: 250px; font-size: 0.8em; }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @keyframes slideOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }
        
        @media (max-width: 400px) {
            .tarifa-actual { font-size: 3.5em; }
            .btn { padding: 10px; font-size: 0.8em; }
        }
    </style>
</head>
<body>
    <div class="taximetro-container" id="appContainer">
        <!-- HEADER -->
        <div class="header">
            <span class="taxi-icon">🚕</span>
            <div class="header-text"><h1>TAXÍMETRO EDOMEX</h1><span class="edomex-badge">EDO. MÉXICO</span></div>
            <div id="tarifaIndicator" class="tarifa-indicator tarifa-diurna">☀️ DIURNA</div>
        </div>
        
        <!-- CONTENIDO PRINCIPAL -->
        <div class="main-content" id="mainContent">
            <div class="hora-actual" id="horaActual"></div>
            <div class="debug-info" id="debugInfo"><strong>🔍</strong> <span id="debugText"></span></div>
            
            <div class="display-principal">
                <div class="tarifa-actual" id="tarifaActual">$0.00</div>
                <div class="info-viaje">
                    <div class="info-item"><div class="info-label">Km</div><div class="info-value" id="kmRecorridos">0</div></div>
                    <div class="info-item"><div class="info-label">Tiempo</div><div class="info-value" id="tiempoTranscurrido">00:00</div></div>
                    <div class="info-item"><div class="info-label">Espera</div><div class="info-value" id="tiempoEspera">0m</div></div>
                    <div class="info-item"><div class="info-label">Vel</div><div class="info-value" id="velocidad">0</div></div>
                </div>
                <div class="gps-status"><div class="gps-dot gps-inactive" id="gpsDot"></div><span id="gpsStatus">GPS: Buscando...</span></div>
                <div class="coords-info" id="coordsInfo"></div>
                <div class="espera-container">
                    <div class="espera-info-text" id="esperaInfoText">⏳ ESPERA: $<span id="esperaCobroActual">0.00</span></div>
                    <div class="progreso-espera"><div class="progreso-espera-fill" id="progresoEspera"></div></div>
                    <div style="font-size:0.45em;color:#888;text-align:center;" id="esperaSegundos">0/60s</div>
                </div>
                <div class="barra-estado">
                    <div id="estadoServicioMini" class="estado-servicio-mini estado-libre-mini">LIBRE</div>
                    <span>🎯 <span id="precisionMetros">0m</span></span>
                </div>
            </div>
            
            <!-- BOTÓN GOOGLE MAPS -->
            <button class="btn btn-maps" onclick="abrirGoogleMaps()" style="margin-top:8px;">
                🗺️ PONER DESTINO EN GOOGLE MAPS
            </button>
            
            <!-- BOTONES PRINCIPALES -->
            <div class="btn-row">
                <button class="btn btn-iniciar" id="btnIniciar" onclick="iniciarServicio()">🟢 INICIAR</button>
                <button class="btn btn-detener" id="btnDetener" onclick="detenerServicio()" disabled>🔴 DETENER</button>
            </div>
            <div class="btn-row">
                <button class="btn btn-cobrar" id="btnCobrar" onclick="confirmarCobro()">💰 COBRAR</button>
                <button class="btn btn-cancelar-cobro" id="btnCancelarCobro" onclick="cancelarCobro()">❌ CANCELAR</button>
            </div>
            
            <!-- BOTONES INFERIORES -->
            <div style="display: flex; gap: 5px; margin-top: auto; flex-shrink: 0;">
                <button class="btn btn-historial" onclick="mostrarHistorialPage()" style="flex:1;">📋 HISTORIAL</button>
                <button class="btn btn-exportar" onclick="mostrarExportModal()" style="flex:1;">📤 EXPORTAR</button>
                <button class="btn btn-config" onclick="mostrarConfigPage()">⚙️</button>
            </div>
        </div>
        
        <!-- PÁGINA DE CONFIGURACIÓN -->
        <div class="config-page" id="configPage">
            <h3 style="text-align:center;margin-bottom:10px;">⚙️ Configuración</h3>
            <div class="config-section">
                <div class="config-title">🔐 Tarifas <button class="btn btn-desbloquear" onclick="mostrarModalPassword()">🔓 DESBLOQUEAR</button></div>
                <div id="configContent" class="config-bloqueada">
                    <div class="input-group"><label>🐛 Depuración:</label><input type="checkbox" id="modoDebug" onchange="toggleModoDebug()"></div>
                    <div class="input-group"><label>🚫 Vel. mínima (km/h):</label><input type="number" id="velMinima" value="3" step="1" min="1" max="20"></div>
                    <div class="tarifa-section">
                        <div class="config-title">☀️ Diurna (5 AM - 10 PM)</div>
                        <div class="input-group"><label>Banderazo ($):</label><input type="number" id="banderazoDiurno" value="9.00" step="0.01" min="0"></div>
                        <div class="input-group"><label>Km ($):</label><input type="number" id="precioKmDiurno" value="0.14" step="0.01" min="0"></div>
                        <div class="input-group"><label>Min espera ($):</label><input type="number" id="precioEsperaDiurno" value="0.14" step="0.01" min="0"></div>
                    </div>
                    <div class="tarifa-section tarifa-nocturna-section">
                        <div class="config-title">🌙 Nocturna (10 PM - 5 AM)</div>
                        <div class="input-group"><label>Banderazo ($):</label><input type="number" id="banderazoNocturno" value="11.00" step="0.01" min="0"></div>
                        <div class="input-group"><label>Km ($):</label><input type="number" id="precioKmNocturno" value="0.17" step="0.01" min="0"></div>
                        <div class="input-group"><label>Min espera ($):</label><input type="number" id="precioEsperaNocturno" value="0.17" step="0.01" min="0"></div>
                    </div>
                </div>
            </div>
            <button class="btn btn-volver" onclick="volverAlPrincipal()">⬅️ VOLVER AL TAXÍMETRO</button>
        </div>
        
        <!-- PÁGINA DE HISTORIAL -->
        <div class="historial-page" id="historialPage">
            <h3 style="text-align:center;margin-bottom:10px;">📊 Historial</h3>
            <div class="estadisticas-rapidas" id="estadisticasRapidas"></div>
            <div id="historialContainer"></div>
            <button class="btn btn-volver" onclick="volverAlPrincipal()">⬅️ VOLVER AL TAXÍMETRO</button>
            <button class="btn btn-detener" onclick="limpiarHistorial()" style="width:100%;margin-top:5px;font-size:0.7em;">🗑️ LIMPIAR HISTORIAL</button>
        </div>
    </div>

    <!-- MODALES -->
    <div id="passwordModal" class="modal">
        <div class="modal-content">
            <h3>🔐 Administrador</h3>
            <input type="password" id="passwordInput" placeholder="Contraseña" maxlength="10">
            <div style="display: flex; gap: 8px; margin-top: 10px;">
                <button class="btn btn-iniciar" onclick="verificarPassword()" style="flex:1;">✅ DESBLOQUEAR</button>
                <button class="btn" onclick="cerrarModal('passwordModal')" style="flex:1;background:#95a5a6;">CANCELAR</button>
            </div>
        </div>
    </div>

    <div id="exportModal" class="modal">
        <div class="modal-content">
            <h3>📤 Exportar</h3>
            <select id="exportFormat" style="width:100%;padding:8px;margin:10px 0;"><option value="csv">CSV (Excel)</option><option value="json">JSON</option></select>
            <textarea id="exportData" readonly></textarea>
            <div style="display: flex; gap: 8px; margin-top: 10px;">
                <button class="btn btn-exportar" onclick="descargarArchivo()" style="flex:1;font-size:0.8em;">💾 DESCARGAR</button>
                <button class="btn btn-exportar" onclick="copiarPortapapeles()" style="flex:1;font-size:0.8em;">📋 COPIAR</button>
            </div>
        </div>
    </div>

    <script>
        // ===================== FUNCIONES DE NAVEGACIÓN =====================
        function mostrarConfigPage() {
            document.getElementById('mainContent').style.display = 'none';
            document.getElementById('configPage').classList.add('activo');
            document.getElementById('historialPage').classList.remove('activo');
        }
        function mostrarHistorialPage() {
            document.getElementById('mainContent').style.display = 'none';
            document.getElementById('historialPage').classList.add('activo');
            document.getElementById('configPage').classList.remove('activo');
            if (window.app) app.mostrarHistorial();
        }
        function volverAlPrincipal() {
            document.getElementById('mainContent').style.display = 'flex';
            document.getElementById('configPage').classList.remove('activo');
            document.getElementById('historialPage').classList.remove('activo');
        }
        function abrirGoogleMaps() {
            window.open('https://www.google.com/maps/dir/?api=1&travelmode=driving', '_blank');
        }
        function cerrarModal(id) { document.getElementById(id).style.display = 'none'; }

        // ===================== CONFIGURACIÓN =====================
        const CONFIG_URL = 'https://jjfabvyv-oss.github.io/taximetro-edomex/config.json';
        let remoteConfig = null;
        
        async function cargarConfiguracionRemota() {
            try {
                const response = await fetch(CONFIG_URL);
                if (response.ok) { remoteConfig = await response.json(); aplicarConfiguracionRemota(); }
            } catch(e) { cargarConfigLocal(); }
        }
        function aplicarConfiguracionRemota() {
            if (!remoteConfig?.tarifas) return;
            const t = remoteConfig.tarifas;
            document.getElementById('banderazoDiurno').value = t.diurna.banderazo;
            document.getElementById('precioKmDiurno').value = t.diurna.precioKm;
            document.getElementById('precioEsperaDiurno').value = t.diurna.precioEspera;
            document.getElementById('banderazoNocturno').value = t.nocturna.banderazo;
            document.getElementById('precioKmNocturno').value = t.nocturna.precioKm;
            document.getElementById('precioEsperaNocturno').value = t.nocturna.precioEspera;
            document.getElementById('velMinima').value = remoteConfig.velMinima || 3;
        }
        function cargarConfigLocal() {
            const c = JSON.parse(localStorage.getItem('taximetroConfig'));
            if (c) {
                document.getElementById('banderazoDiurno').value = c.banderazoDiurno || 9;
                document.getElementById('precioKmDiurno').value = c.precioKmDiurno || 0.14;
                document.getElementById('precioEsperaDiurno').value = c.precioEsperaDiurno || 0.14;
                document.getElementById('banderazoNocturno').value = c.banderazoNocturno || 11;
                document.getElementById('precioKmNocturno').value = c.precioKmNocturno || 0.17;
                document.getElementById('precioEsperaNocturno').value = c.precioEsperaNocturno || 0.17;
                document.getElementById('velMinima').value = c.velMinima || 3;
            }
        }
        function getPassword() {
            if (remoteConfig?.password) return remoteConfig.password;
            return localStorage.getItem('taximetroPassword') || '1234';
        }
        function mostrarModalPassword() {
            document.getElementById('passwordModal').style.display = 'flex';
            document.getElementById('passwordInput').value = '';
        }
        function verificarPassword() {
            if (document.getElementById('passwordInput').value === getPassword()) {
                document.getElementById('configContent').classList.remove('config-bloqueada');
                cerrarModal('passwordModal');
                if (window.app) app.mostrarNotificacion('✅ Desbloqueado');
                setTimeout(() => document.getElementById('configContent').classList.add('config-bloqueada'), 120000);
            } else {
                if (window.app) app.mostrarNotificacion('❌ Incorrecta');
            }
        }

        // ===================== APP =====================
        class TaximetroApp {
            constructor() {
                this.servicioActivo = false; this.watchId = null; this.wakeLock = null;
                this.ultimaPosicion = null; this.kmAcumulados = 0; this.kmCobrados = 0;
                this.segundosEspera = 0; this.minutosCobrados = 0;
                this.tiempoInicio = null; this.enEspera = false; this.inicioEspera = null;
                this.historial = JSON.parse(localStorage.getItem('taximetroHistorial') || '[]');
                this.timerInterval = null; this.horaCheckInterval = null;
                this.gpsActivo = false; this.precisionActual = 0; this.modoDebug = false;
                this.esperandoCobro = false;
                this.iniciarMonitorHorario(); this.verificarTarifaActual();
                const d = JSON.parse(localStorage.getItem('taximetroDebug'));
                if(d) { document.getElementById('modoDebug').checked = d.modoDebug || false; this.modoDebug = d.modoDebug || false; }
            }
            async activarWakeLock() { try { if ('wakeLock' in navigator) this.wakeLock = await navigator.wakeLock.request('screen'); } catch(e) {} }
            async desactivarWakeLock() { if (this.wakeLock) { await this.wakeLock.release(); this.wakeLock = null; } }
            actualizarEstadoServicio(e) {
                const m = document.getElementById('estadoServicioMini');
                if (e === 'cobro') { m.className = 'estado-servicio-mini estado-cobro-mini'; m.textContent = '💳 PAGANDO'; }
                else if (this.servicioActivo) { m.className = 'estado-servicio-mini estado-ocupado-mini'; m.textContent = 'EN SERVICIO'; }
                else { m.className = 'estado-servicio-mini estado-libre-mini'; m.textContent = 'LIBRE'; }
            }
            logDebug(m) { console.log(m); if (this.modoDebug) { document.getElementById('debugText').textContent = m; document.getElementById('debugInfo').classList.add('show'); } }
            toggleModoDebug() { this.modoDebug = document.getElementById('modoDebug').checked; localStorage.setItem('taximetroDebug', JSON.stringify({modoDebug:this.modoDebug})); if(!this.modoDebug) document.getElementById('debugInfo').classList.remove('show'); }
            esHorarioNocturno() { return new Date().getHours() >= 22 || new Date().getHours() < 5; }
            obtenerTarifaActual() {
                const n = this.esHorarioNocturno();
                return {
                    banderazo: parseFloat(document.getElementById(n?'banderazoNocturno':'banderazoDiurno').value)||9,
                    precioKm: parseFloat(document.getElementById(n?'precioKmNocturno':'precioKmDiurno').value)||0.14,
                    precioEspera: parseFloat(document.getElementById(n?'precioEsperaNocturno':'precioEsperaDiurno').value)||0.14,
                    tipo: n?'nocturna':'diurna'
                };
            }
            verificarTarifaActual() {
                const n = this.esHorarioNocturno(), ind = document.getElementById('tarifaIndicator');
                if(n){ind.className='tarifa-indicator tarifa-nocturna';ind.textContent='🌙 NOCTURNA';}
                else{ind.className='tarifa-indicator tarifa-diurna';ind.textContent='☀️ DIURNA';}
            }
            iniciarMonitorHorario() { this.actualizarHoraActual(); this.horaCheckInterval = setInterval(()=>{this.actualizarHoraActual();this.verificarTarifaActual();}, 1000); }
            actualizarHoraActual() {
                const a = new Date();
                document.getElementById('horaActual').textContent = a.toLocaleDateString('es-MX',{weekday:'long',year:'numeric',month:'long',day:'numeric'})+' - '+a.toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:true});
            }
            calcularDistancia(lat1,lon1,lat2,lon2) {
                const R=6371,dLat=(lat2-lat1)*Math.PI/180,dLon=(lon2-lon1)*Math.PI/180;
                const a=Math.sin(dLat/2)**2+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
                return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
            }
            actualizarEstadoSensores(g) {
                this.gpsActivo=g;
                document.getElementById('gpsDot').className='gps-dot '+(g?'gps-active':'gps-inactive');
                document.getElementById('gpsStatus').textContent=g?'GPS: Activo ✓':'GPS: Buscando...';
            }
            async iniciarServicio() {
                if(!navigator.geolocation){alert('GPS no soportado');return;}
                this.servicioActivo=true;this.esperandoCobro=false;
                this.kmAcumulados=0;this.kmCobrados=0;this.segundosEspera=0;this.minutosCobrados=0;
                this.tiempoInicio=Date.now();this.enEspera=false;this.ultimaPosicion=null;
                document.getElementById('btnIniciar').disabled=true;
                document.getElementById('btnDetener').disabled=false;
                document.getElementById('btnCobrar').classList.remove('activo');
                document.getElementById('btnCancelarCobro').classList.remove('activo');
                this.actualizarEstadoServicio('servicio');this.actualizarEstadoSensores(false);
                await this.activarWakeLock();this.iniciarGPS();this.iniciarTimer();this.actualizarDisplay();
            }
            iniciarGPS() {
                navigator.geolocation.getCurrentPosition(
                    (pos)=>{
                        this.ultimaPosicion={lat:pos.coords.latitude,lon:pos.coords.longitude,timestamp:pos.timestamp};
                        this.precisionActual=pos.coords.accuracy||5;
                        this.actualizarEstadoSensores(true);this.actualizarDisplay();this.iniciarMonitoreoGPS();
                    },
                    (e)=>{this.actualizarEstadoSensores(false);setTimeout(()=>this.iniciarGPS(),3000);},
                    {enableHighAccuracy:true,timeout:10000,maximumAge:0}
                );
            }
            iniciarMonitoreoGPS() {
                if(this.watchId)navigator.geolocation.clearWatch(this.watchId);
                this.watchId=navigator.geolocation.watchPosition(
                    (pos)=>{
                        if(!this.servicioActivo&&!this.esperandoCobro)return;
                        const np={lat:pos.coords.latitude,lon:pos.coords.longitude,timestamp:pos.timestamp,velocidad:pos.coords.speed?pos.coords.speed*3.6:0};
                        this.precisionActual=pos.coords.accuracy||5;
                        if(this.ultimaPosicion){
                            const d=this.calcularDistancia(this.ultimaPosicion.lat,this.ultimaPosicion.lon,np.lat,np.lon);
                            if(d<0.1&&d>0.002){
                                this.kmAcumulados+=d;
                                if(this.kmAcumulados>=(this.kmCobrados+1)*0.8){
                                    this.kmCobrados=Math.floor(this.kmAcumulados);
                                    this.animarSalto('kmRecorridos');this.animarSalto('tarifaActual');
                                }
                                const vm=parseInt(document.getElementById('velMinima').value)||3;
                                if(np.velocidad<vm&&!this.enEspera){this.enEspera=true;this.inicioEspera=Date.now();}
                                else if(np.velocidad>=vm&&this.enEspera){this.enEspera=false;this.inicioEspera=null;}
                            }
                        }
                        this.ultimaPosicion=np;this.actualizarEstadoSensores(true);
                        document.getElementById('coordsInfo').textContent='📍 '+np.lat.toFixed(5)+', '+np.lon.toFixed(5)+' | Vel: '+np.velocidad.toFixed(1)+' km/h';
                        this.actualizarDisplay();
                    },
                    (e)=>{this.actualizarEstadoSensores(false);},
                    {enableHighAccuracy:true,timeout:10000,maximumAge:0,distanceFilter:0}
                );
            }
            async detenerServicio() {
                if(this.watchId){navigator.geolocation.clearWatch(this.watchId);this.watchId=null;}
                this.servicioActivo=false;this.esperandoCobro=true;
                document.getElementById('btnIniciar').disabled=true;
                document.getElementById('btnDetener').disabled=true;
                document.getElementById('btnCobrar').classList.add('activo');
                document.getElementById('btnCancelarCobro').classList.add('activo');
                this.actualizarEstadoServicio('cobro');
            }
            async confirmarCobro() {
                this.historial.unshift({id:Date.now(),fecha:new Date().toLocaleString(),cobrado:true,kmCobrados:this.kmCobrados,minutosEspera:this.minutosCobrados,tiempo:this.calcularTiempoTranscurrido(),tarifa:document.getElementById('tarifaActual').textContent,tipoTarifa:this.obtenerTarifaActual().tipo});
                if(this.historial.length>100)this.historial.pop();
                localStorage.setItem('taximetroHistorial',JSON.stringify(this.historial));
                this.finalizarViaje();
            }
            async cancelarCobro() {
                if(!confirm('¿Cancelar cobro? Se guardará como NO cobrado.'))return;
                this.historial.unshift({id:Date.now(),fecha:new Date().toLocaleString(),cobrado:false,kmCobrados:this.kmCobrados,minutosEspera:this.minutosCobrados,tiempo:this.calcularTiempoTranscurrido(),tarifa:document.getElementById('tarifaActual').textContent,tipoTarifa:this.obtenerTarifaActual().tipo});
                if(this.historial.length>100)this.historial.pop();
                localStorage.setItem('taximetroHistorial',JSON.stringify(this.historial));
                this.finalizarViaje();
            }
            async finalizarViaje() {
                this.esperandoCobro=false;this.kmAcumulados=0;this.kmCobrados=0;
                this.segundosEspera=0;this.minutosCobrados=0;this.tiempoInicio=null;this.enEspera=false;
                document.getElementById('btnIniciar').disabled=false;
                document.getElementById('btnDetener').disabled=true;
                document.getElementById('btnCobrar').classList.remove('activo');
                document.getElementById('btnCancelarCobro').classList.remove('activo');
                this.actualizarEstadoServicio('libre');
                if(this.timerInterval)clearInterval(this.timerInterval);
                await this.desactivarWakeLock();
                this.actualizarEstadoSensores(false);
                document.getElementById('esperaInfoText').classList.remove('activo');
                document.getElementById('progresoEspera').style.width='0%';
                this.actualizarDisplay();
            }
            calcularTarifa() { const t=this.obtenerTarifaActual(); return t.banderazo+(this.kmCobrados*t.precioKm)+(this.minutosCobrados*t.precioEspera); }
            calcularTiempoTranscurrido() { if(!this.tiempoInicio)return'00:00'; const t=Math.floor((Date.now()-this.tiempoInicio)/1000); return String(Math.floor(t/60)).padStart(2,'0')+':'+String(t%60).padStart(2,'0'); }
            animarSalto(id) { const el=document.getElementById(id); if(id==='tarifaActual'){el.classList.add('salto');setTimeout(()=>el.classList.remove('salto'),400);}else{el.classList.add('saltando');setTimeout(()=>el.classList.remove('saltando'),300);} }
            iniciarTimer() {
                if(this.timerInterval)clearInterval(this.timerInterval);
                this.timerInterval=setInterval(()=>{
                    if(!this.servicioActivo&&!this.esperandoCobro)return;
                    if(this.enEspera&&this.inicioEspera){
                        this.segundosEspera=Math.floor((Date.now()-this.inicioEspera)/1000);
                        const s=this.segundosEspera%60;
                        document.getElementById('progresoEspera').style.width=(s/60*100)+'%';
                        document.getElementById('esperaSegundos').textContent=s+'/60s';
                        document.getElementById('esperaCobroActual').textContent=(this.minutosCobrados*this.obtenerTarifaActual().precioEspera).toFixed(2);
                        document.getElementById('esperaInfoText').classList.add('activo');
                        if(this.segundosEspera>=(this.minutosCobrados+1)*48){this.minutosCobrados=Math.floor(this.segundosEspera/60);this.animarSalto('tiempoEspera');this.animarSalto('tarifaActual');}
                    }else{
                        document.getElementById('esperaInfoText').classList.remove('activo');
                        document.getElementById('progresoEspera').style.width='0%';
                        document.getElementById('esperaSegundos').textContent='0/60s';
                    }
                    this.actualizarDisplay();
                },1000);
            }
            actualizarDisplay() {
                if(!this.servicioActivo&&!this.esperandoCobro){
                    document.getElementById('tarifaActual').textContent='$0.00';
                    document.getElementById('kmRecorridos').textContent='0';
                    document.getElementById('tiempoTranscurrido').textContent='00:00';
                    document.getElementById('tiempoEspera').textContent='0m';
                    document.getElementById('velocidad').textContent='0';
                    document.getElementById('precisionMetros').textContent='0m';
                    return;
                }
                document.getElementById('tarifaActual').textContent='$'+this.calcularTarifa().toFixed(2);
                document.getElementById('kmRecorridos').textContent=this.kmCobrados;
                document.getElementById('tiempoTranscurrido').textContent=this.calcularTiempoTranscurrido();
                document.getElementById('tiempoEspera').textContent=this.minutosCobrados+'m';
                document.getElementById('velocidad').textContent=this.ultimaPosicion?this.ultimaPosicion.velocidad.toFixed(0):'0';
                document.getElementById('precisionMetros').textContent=Math.round(this.precisionActual)+'m';
            }
            exportarCSV() { let c='Fecha,Tipo,Km,Min Espera,Tarifa,Cobrado\n'; this.historial.forEach(v=>{c+=`"${v.fecha}","${v.tipoTarifa}",${v.kmCobrados||0},${v.minutosEspera||0},"${v.tarifa}","${v.cobrado!==false?'SI':'NO'}"\n`;}); return c; }
            exportarJSON() { return JSON.stringify({fecha:new Date().toISOString(),viajes:this.historial},null,2); }
            mostrarHistorial() {
                const c=document.getElementById('historialContainer');c.innerHTML='';
                if(!this.historial.length){c.innerHTML='<p style="text-align:center;color:#999;">Sin viajes</p>';document.getElementById('estadisticasRapidas').innerHTML='';return;}
                const cob=this.historial.filter(v=>v.cobrado!==false);
                document.getElementById('estadisticasRapidas').innerHTML=`<div class="stat-item">💰 $${cob.reduce((s,v)=>s+parseFloat(v.tarifa.replace('$','')),0).toFixed(2)}</div><div class="stat-item">🚗 ${this.historial.length} viajes</div><div class="stat-item">❌ ${this.historial.filter(v=>v.cobrado===false).length} canc.</div>`;
                this.historial.forEach((v,i)=>{
                    const d=document.createElement('div');
                    d.className='historial-item'+(v.tipoTarifa==='nocturna'?' nocturno':'')+(v.cobrado===false?' cancelado':'');
                    d.innerHTML=`<strong>#${i+1} - ${v.tipoTarifa==='nocturna'?'🌙':'☀️'} ${v.tipoTarifa?.toUpperCase()} ${v.cobrado===false?'❌ NO COBRADO':'✅'}</strong><br>📅 ${v.fecha}<br>📍 ${v.kmCobrados||0} km | ⏳ ${v.minutosEspera||0} min<br>💰 ${v.tarifa}`;
                    c.appendChild(d);
                });
            }
            mostrarNotificacion(m) {
                const n=document.createElement('div');n.className='notification';n.textContent=m;
                document.body.appendChild(n);
                setTimeout(()=>{n.style.animation='slideOut 0.3s ease';setTimeout(()=>n.remove(),300);},3000);
            }
        }

        // INICIAR
        async function initApp() {
            await cargarConfiguracionRemota();
            window.app = new TaximetroApp();
        }
        initApp();
        
        function iniciarServicio() { if(window.app) app.iniciarServicio(); }
        function detenerServicio() { if(window.app) app.detenerServicio(); }
        function confirmarCobro() { if(window.app) app.confirmarCobro(); }
        function cancelarCobro() { if(window.app) app.cancelarCobro(); }
        function limpiarHistorial() { if(confirm('¿Eliminar todo?')&&window.app){app.historial=[];localStorage.setItem('taximetroHistorial','[]');app.mostrarHistorial();app.mostrarNotificacion('Historial eliminado');}}
        function mostrarExportModal() { document.getElementById('exportModal').style.display='flex'; actualizarExportData(); }
        function actualizarExportData() { if(!window.app)return; document.getElementById('exportData').value=document.getElementById('exportFormat').value==='csv'?app.exportarCSV():app.exportarJSON(); }
        document.getElementById('exportFormat').addEventListener('change',actualizarExportData);
        function descargarArchivo() { const f=document.getElementById('exportFormat').value,d=document.getElementById('exportData').value,b=new Blob([d],{type:'text/plain'}),u=URL.createObjectURL(b),a=document.createElement('a');a.href=u;a.download=`taximetro_edomex_${new Date().toISOString().slice(0,10)}.${f}`;a.click();URL.revokeObjectURL(u);if(window.app)app.mostrarNotificacion('✅ Descargado');}
        async function copiarPortapapeles() { try{await navigator.clipboard.writeText(document.getElementById('exportData').value);if(window.app)app.mostrarNotificacion('✅ Copiado');}catch(e){}}
        window.onclick=function(e){if(e.target.className==='modal')e.target.style.display='none';}
    </script>
